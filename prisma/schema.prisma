// Prisma schema for Umrah Platform - Libyan Market
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= Users / Accounts =============
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("CUSTOMER") // SUPER_ADMIN | COMPANY | CUSTOMER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company?
  orders       Order[]
  messages     Message[]
}

// ============= Umrah Companies =============
model Company {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  logo            String?
  description     String?
  licenseNumber   String?
  phone           String
  whatsapp        String?
  email           String?
  address         String?
  city            String?
  country         String  @default("ليبيا")
  website         String?

  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED | SUSPENDED
  rating          Float    @default(0)

  // Featured company (requires admin approval)
  isFeatured      Boolean  @default(false)
  featuredStatus  String   @default("NONE") // NONE | PENDING | APPROVED | REJECTED

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  packages        Package[]
  orders          Order[]
}

// ============= Packages =============
model Package {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title           String
  description     String
  type            String   @default("UMRAH") // UMRAH | HAJJ | COMBINED | RAMADAN
  durationDays    Int
  price           Float
  oldPrice        Float?   // for discount display
  currency        String   @default("LYD")

  hotelStars      Int      @default(3)
  hotelName       String?
  includesTransport Boolean @default(true)
  includesMeals   Boolean  @default(false)
  includesGuide   Boolean  @default(true)
  includesZiyarat Boolean  @default(true)

  departureDate   String?
  availableSeats  Int      @default(0)
  features        String?  // JSON string of features list

  isActive        Boolean  @default(true)

  // Featured package (requires admin approval - paid promotion)
  isFeatured      Boolean  @default(false)
  featuredStatus  String   @default("NONE") // NONE | PENDING | APPROVED | REJECTED

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders          Order[]
}

// ============= Orders =============
model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique

  packageId       String
  package         Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId      String?
  customer        User?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Customer details (could be guest)
  customerName    String
  customerPhone   String
  customerEmail   String?
  numPersons      Int      @default(1)
  notes           String?

  totalPrice      Float
  currency        String   @default("LYD")

  status          String   @default("PENDING_PAYMENT") // PENDING_PAYMENT | PAID | CANCELLED | COMPLETED
  paymentMethod   String   @default("WHATSAPP")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        Message[]
}

// ============= Promotions / Discount Offers =============
model Promotion {
  id              String   @id @default(cuid())
  title           String
  description     String?
  banner          String?

  discountType    String   @default("PERCENTAGE") // PERCENTAGE | FIXED
  discountValue   Float    @default(0)

  appliesTo       String   @default("ALL") // ALL | PACKAGE | COMPANY
  packageId       String?
  companyId       String?

  startDate       String
  endDate         String

  // Approval system
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============= Messages (Auto notifications for customers) =============
model Message {
  id              String   @id @default(cuid())
  customerId      String
  customer        User     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type            String   // BOOKING_CONFIRMATION | PAYMENT_REMINDER | APPOINTMENT_REMINDER | UMRAH_GUIDE | PRE_DEPARTURE | WELCOME | STATUS_UPDATE
  title           String
  content         String
  isRead          Boolean  @default(false)

  createdAt       DateTime @default(now())
}

// ============= Site Settings (CMS - editable by admin) =============
model Setting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  updatedAt       DateTime @updatedAt
}

// ============= Login Attempts (Audit Log - #3) =============
model LoginAttempt {
  id              String   @id @default(cuid())
  email           String?
  ip              String
  userAgent       String?
  success         Boolean
  failureReason   String?
  country         String?
  city            String?
  createdAt       DateTime @default(now())

  @@index([ip])
  @@index([email])
  @@index([createdAt])
}

// ============= Banned IPs (Auto IP Ban - #4) =============
model BannedIP {
  id              String   @id @default(cuid())
  ip              String   @unique
  reason          String
  attemptCount    Int      @default(0)
  bannedUntil     DateTime
  bannedPermanently Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ip])
  @@index([bannedUntil])
}

// ============= File Uploads (Secure File Upload - #7) =============
model FileUpload {
  id              String   @id @default(cuid())
  filename        String   // الاسم الجديد العشوائي
  originalName    String   // الاسم الأصلي
  mimeType        String
  size            Int      // بالبايت
  url             String   // رابط الوصول
  uploadedById    String?  // معرف المستخدم الذي رفع الملف
  purpose         String   // logo, package_pdf, etc.
  virusScanned    Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([uploadedById])
}

// ============= Security Events (للمراقبة الأمنية) =============
model SecurityEvent {
  id              String   @id @default(cuid())
  type            String   // LOGIN_BLOCKED, IP_BANNED, SUSPICIOUS_ACTIVITY, etc.
  severity        String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  ip              String?
  userId          String?
  description     String
  metadata        String?  // JSON
  createdAt       DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([createdAt])
}
