// Prisma schema for Umrah Platform
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============= Users / Accounts =============
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("CUSTOMER") // SUPER_ADMIN | COMPANY | CUSTOMER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company?
  orders    Order[]
}

// ============= Umrah Companies =============
model Company {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  logo            String?
  description     String?
  licenseNumber   String?
  phone           String
  whatsapp        String?
  email           String?
  address         String?
  city            String?
  country         String  @default("ليبيا")
  website         String?

  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED | SUSPENDED
  rating          Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  packages        Package[]
  orders          Order[]
}

// ============= Packages =============
model Package {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title           String
  description     String
  type            String   @default("UMRAH") // UMRAH | HAJJ | COMBINED | RAMADAN
  durationDays    Int
  price           Float
  oldPrice        Float?   // for discount display
  currency        String   @default("LYD")

  hotelStars      Int      @default(3)
  hotelName       String?
  includesTransport Boolean @default(true)
  includesMeals   Boolean  @default(false)
  includesGuide   Boolean  @default(true)
  includesZiyarat Boolean  @default(true)

  departureDate   String?
  availableSeats  Int      @default(0)
  features        String?  // JSON string of features list

  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders          Order[]
}

// ============= Orders =============
model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique

  packageId       String
  package         Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId      String?
  customer        User?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Customer details (could be guest)
  customerName    String
  customerPhone   String
  customerEmail   String?
  numPersons      Int      @default(1)
  notes           String?

  totalPrice      Float
  currency        String   @default("LYD")

  status          String   @default("PENDING_PAYMENT") // PENDING_PAYMENT | PAID | CANCELLED | COMPLETED
  paymentMethod   String   @default("WHATSAPP")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============= Promotions / Discount Offers (managed by Super Admin) =============
model Promotion {
  id              String   @id @default(cuid())
  title           String
  description     String?
  banner          String?

  discountType    String   @default("PERCENTAGE") // PERCENTAGE | FIXED
  discountValue   Float    @default(0)

  appliesTo       String   @default("ALL") // ALL | PACKAGE | COMPANY
  packageId       String?
  companyId       String?

  startDate       String
  endDate         String

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============= Site Settings (Super Admin) =============
model Setting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  updatedAt       DateTime @updatedAt
}
