# ====================================
# متغيرات البيئة لمنصة عمرة ليبيا
# Environment Variables for Umrah Libya Platform
# ====================================

# قاعدة البيانات - Database
# للاستخدام المحلي (SQLite):
DATABASE_URL="file:./db/custom.db"

# للنشر على Vercel، استخدم PostgreSQL (مجاني من Vercel أو Neon):
# DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# مفتاح تشفير JWT (غيّره إلى قيمة عشوائية طويلة في الإنتاج)
JWT_SECRET="umrah-libya-jwt-secret-key-2026-change-this-in-production"

# رابط الموقع (يُستخدم في الروابط والمصادقة)
NEXTAUTH_URL="http://localhost:3000"

# في النشر: NEXTAUTH_URL="https://your-domain.com"

# ====================================
# ملاحظات مهمة للنشر:
# 1. على Vercel: ضع هذه المتغيرات في Settings > Environment Variables
# 2. غيّر JWT_SECRET إلى قيمة عشوائية قوية
# 3. استخدم PostgreSQL بدلاً من SQLite للإنتاج
# ====================================
