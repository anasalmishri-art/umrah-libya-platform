# ====================================
# متغيرات البيئة - منصة عمرة ليبيا
# Environment Variables - Umrah Libya Platform
# ====================================

# ===== قاعدة البيانات =====
DATABASE_URL="file:./db/custom.db"
# للنشر: DATABASE_URL="postgresql://..."

# ===== مفتاح تشفير JWT =====
JWT_SECRET="umrah-libya-jwt-secret-key-2026-change-this"

# ===== رابط الموقع =====
NEXTAUTH_URL="http://localhost:3000"

# ===== مفتاح تشفير البيانات الحساسة (AES-256) - #8 =====
# يجب أن يكون 32 بايت (32 حرف)
ENCRYPTION_KEY="umrah-libya-encryption-key-32"

# ===== Upstash Redis (لـ Rate Limiting المتقدم) - #12 =====
# احصل عليها مجاناً من: https://upstash.com
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# ===== مفتاح النسخ الاحتياطي الأسبوعي - #13 =====
CRON_SECRET="umrah-libya-backup-secret-2026"

# ===== ملاحظات =====
# 1. على Vercel: ضع هذه المتغيرات في Settings > Environment Variables
# 2. غيّر JWT_SECRET و ENCRYPTION_KEY و CRON_SECRET في الإنتاج
# 3. Upstash اختياري - إذا لم يكن موجوداً، يستخدم النظام الذاكرة المحلية
