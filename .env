# ====================================
# متغيرات البيئة - منصة عمرة ليبيا
# Environment Variables - Umrah Libya Platform
# ====================================

# قاعدة البيانات - Database
DATABASE_URL=file:/home/z/my-project/db/custom.db

# مفتاح تشفير JWT (غيّره في الإنتاج!)
JWT_SECRET=umrah-libya-jwt-secret-key-2026-production-change-me

# رابط الموقع
NEXTAUTH_URL=http://localhost:3000

# ====================================
# للنشر على Vercel، استبدل القيم أعلاه بـ:
# DATABASE_URL=postgresql://user:pass@host:port/db?schema=public
# JWT_SECRET=<مفتاح-عشوائي-طويل>
# NEXTAUTH_URL=https://your-domain.vercel.app
# ====================================
